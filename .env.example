# ─── Backend Environment Variables ──────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to git — add it to .gitignore

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT secret — generate a strong secret with: openssl rand -base64 64
JWT_SECRET=<generate-a-strong-random-secret-here>

# Server port
PORT=5000

# Node environment: development | production
NODE_ENV=development

# Frontend URL for CORS (your Netlify domain in production)
FRONTEND_URL=https://your-app.netlify.app

# Google OAuth Client ID (from console.cloud.google.com)
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>.apps.googleusercontent.com
